---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

import Base from "@/layouts/Base.astro";
import CallToAction from "@/partials/CallToAction.astro";
import config from "@/config/config.json";
import { dateFormat } from "@/lib/utils/dateFormat";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const {
  site: { base_url },
} = config;

const title = post.data.title;
const pageTitle = post.data.pageTitle ?? title;
const description = post.data.description;
const publishedTime = post.data.publishedTime;
const modifiedTime = post.data.modifiedTime ?? publishedTime;
const image = post.data.image;
const imageAlt = post.data.imageAlt ?? pageTitle;
const imageCaption = post.data.imageCaption;

// Render the hero at the image's natural aspect ratio so it is never cropped.
// Width is capped for a retina-friendly asset; height follows the source ratio.
const heroWidth = 2640;
const heroHeight = image
  ? Math.round((heroWidth * image.height) / image.width)
  : undefined;

const canonicalUrl = `${base_url}/blog/${post.id}`;
const ogImage = image ? `${base_url}${image.src}` : undefined;

const seo = {
  title: `${title} - RocketSim`,
  description,
  image: ogImage,
  imageAlt: image ? imageAlt : undefined,
  canonical: canonicalUrl,
  twitterCreator: "@twannl",
  twitterSite: "@rocketsim_app",
  article: {
    publishedTime: publishedTime.toISOString(),
    modifiedTime: modifiedTime.toISOString(),
  },
};

const structuredData = {
  type: "article" as const,
  article: {
    headline: pageTitle,
    description,
    datePublished: publishedTime.toISOString(),
    dateModified: modifiedTime.toISOString(),
    url: canonicalUrl,
    slug: post.id,
    image: ogImage
      ? {
          url: ogImage,
          width: image?.width,
          height: image?.height,
        }
      : undefined,
  },
};
---

<Base seo={seo} structuredData={structuredData}>
  <article>
    <header>
      <div class="ph-spacing">
        <div class="container">
          <div class="flex flex-col gap-16 lg:gap-28">
            <div class="space-y-3 md:space-y-5 mx-auto w-full max-w-[680px]">
              <p
                class="text-base font-medium text-text pb-2"
                data-aos="fade-up-sm"
                data-aos-delay="0"
              >
                Last Updated {dateFormat(modifiedTime, "MMM dd, yyyy")}
              </p>
              <h1
                class="page-heading leading-none !mb-6"
                data-aos="fade-up-sm"
                data-aos-delay="50"
              >
                {pageTitle}
              </h1>
            </div>
          </div>
        </div>
      </div>

      {
        image ? (
          <div class="ph-merged-section">
            <div class="container">
              <figure
                class="mx-auto max-w-[1024px]"
                data-aos="fade-up-sm"
                data-aos-delay="150"
              >
                <Image
                  src={image}
                  alt={imageAlt}
                  width={heroWidth}
                  height={heroHeight}
                  class="w-full h-auto rounded-2xl"
                />
                {imageCaption ? (
                  <figcaption class="mt-4 text-center text-sm text-text">
                    {imageCaption}
                  </figcaption>
                ) : null}
              </figure>
            </div>
          </div>
        ) : null
      }
    </header>

    <section class="section -mt-20">
      <div class="container">
        <div class="content mx-auto max-w-[680px]">
          <Content />
        </div>
      </div>
    </section>

    <CallToAction />
  </article>
</Base>

<style>
  .content :global(h1),
  .content :global(h2),
  .content :global(h3),
  .content :global(h4),
  .content :global(h5),
  .content :global(h6) {
    position: relative;

    scroll-margin-top: 6rem;
  }

  .content :global(.heading-anchor) {
    position: absolute;
    top: 0;
    right: calc(100% + 0.5rem);

    display: inline-flex;
    align-items: center;
    height: 1lh;
    padding-top: 0.125em;

    color: inherit;
    text-decoration: none;

    opacity: 0;

    transition: opacity 150ms ease;
  }

  .content :global(.heading-anchor svg) {
    width: 0.5em;
    height: 0.5em;
  }

  .content :global(h1:hover .heading-anchor),
  .content :global(h2:hover .heading-anchor),
  .content :global(h3:hover .heading-anchor),
  .content :global(h4:hover .heading-anchor),
  .content :global(h5:hover .heading-anchor),
  .content :global(h6:hover .heading-anchor),
  .content :global(.heading-anchor:focus-visible) {
    opacity: 1;
  }
</style>
