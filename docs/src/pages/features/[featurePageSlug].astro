---
import { getCollection } from "astro:content";

import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import PageHeader from "@/partials/PageHeader.astro";
import CallToAction from "@/partials/CallToAction.astro";
import FeatureBento from "@/partials/FeatureBento.astro";
import FeatureItems from "@/partials/FeatureItems.astro";

export async function getStaticPaths() {
  const pages = await getCollection("feature-page");
  return pages
    .filter((page) => !page.data.draft)
    .map((page) => ({
      params: { featurePageSlug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
const { title, description, hero, bento } = page.data;
const {
  site: { base_url },
} = config;
const canonicalUrl = `${base_url}/features/${page.id}`;
const featureItems = await getCollection(
  "feature",
  (feature) => feature.data.featurePage === page.id,
);

const seo = {
  title: page.data.meta_title || `${title} - RocketSim`,
  description,
  canonical: canonicalUrl,
};

const structuredData = {
  type: "static" as const,
  page: {
    name: title,
    description,
    url: canonicalUrl,
    breadcrumbName: title,
    about: [title, "RocketSim", "iOS Simulator"],
    itemList: featureItems.map((feature) => ({
      name: feature.data.name,
      description: feature.data.tagLine,
      url: canonicalUrl,
    })),
  },
};
---

<Base seo={seo} structuredData={structuredData}>
  <PageHeader title={hero.title} subtitle={hero.subtitle || ""} />

  {bento?.enable && <FeatureBento title={bento.title} list={bento.list} />}

  <FeatureItems
    featurePage={page.id}
    title={bento?.enable ? `Explore all ${title} features` : undefined}
  />

  <CallToAction />
</Base>

{
  /* Feature videos are lazy-loaded and autoplayed by the script colocated in
    Feature.astro, which handles every `.js-feature-video` on the page. */
}
