---
import { Image } from "astro:assets";

import appIcon from "../../assets/rocketsim-app-icon.png";

interface Props {
  showLogin?: boolean;
  microcopy?: string;
}

const { showLogin = false, microcopy } = Astro.props;
---

<style>
  .navigation-wrapper {
    padding: 1rem 0;

    background-color: #000;
    border-bottom: 0.0625rem solid transparent;

    transition: border-bottom-color 0.3s;
    box-sizing: content-box;
  }

  .navigation__primary {
    @media (min-width: 800px) {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      grid-column: 1 / -2;
    }
  }

  .navigation__logo {
    width: 2.75rem;
    height: auto;
  }

  .navigation__login {
    text-decoration: none;
    color: #fff;
    font-weight: 500;
    margin-right: 1rem;
  }

  .navigation__microcopy {
    margin: 0.75rem 0 0;

    font-size: 0.75rem;
    color: #888;
    text-align: center;

    @media (min-width: 800px) {
      text-align: left;
    }
  }

  .navigation__right-column {
    display: none;
    opacity: 0;
    transition: opacity 0.3s;

    @media (min-width: 800px) {
      display: flex;
      align-items: center;
      grid-column: span 1 / -1;
      gap: 1rem;
      justify-self: end;
    }
  }

  ul {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.125rem;
    padding: 0;
    margin: 0;

    list-style: none;

    @media (min-width: 800px) {
      flex-direction: row;
      gap: 2rem;
    }
  }

  .link--login {
    font-weight: 600;
    text-decoration: none;
  }
</style>

<div class:list={["navigation-wrapper"]} id="navigation-menu">
  <div class="navigation deprecated-grid">
    <div class="navigation__primary">
      <nav aria-label="Hero navigation">
        <ul>
          <slot />
        </ul>
      </nav>
      {microcopy && <p class="navigation__microcopy">{microcopy}</p>}
    </div>
    <div class="navigation__right-column">
      {
        showLogin ? (
          <a href="https://teams.rocketsim.app" class="link link--login">
            Login
          </a>
        ) : null
      }
      <Image
        src={appIcon}
        alt="RocketSim app icon"
        width="88"
        height="88"
        class="navigation__logo"
      />
    </div>
  </div>
</div>
